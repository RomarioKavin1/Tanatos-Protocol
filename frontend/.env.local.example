# Thanatos Protocol — Frontend Environment Variables
# Copy this file to .env.local and fill in the deployed contract addresses.
# Run scripts/deploy.sh to get these addresses (it writes .env.local automatically).

# Deployed contract addresses (Starknet Sepolia)
NEXT_PUBLIC_LIVENESS_REGISTRY_ADDRESS=0x0
NEXT_PUBLIC_VAULT_CONTROLLER_ADDRESS=0x0
NEXT_PUBLIC_KEEPER_REGISTRY_ADDRESS=0x0

# STRK token on Sepolia (pre-filled — do not change for Sepolia)
NEXT_PUBLIC_STRK_TOKEN_ADDRESS=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d

# Network
NEXT_PUBLIC_NETWORK=sepolia

# Optional: override the default public Sepolia RPC
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7
